aws_region             = "us-east-1"
availability_zones     = ["us-east-1a", "us-east-1b"]
public_subnet_cidrs    = ["10.40.0.0/24", "10.40.1.0/24"]
private_subnet_cidrs   = ["10.40.10.0/24", "10.40.11.0/24"]
enable_nat_gateway     = true
single_nat_gateway     = true
offline_validation     = true

api_image              = "000000000000.dkr.ecr.us-east-1.amazonaws.com/kaklen-staging-api:replace-with-immutable-reference"
api_ecr_repository_arn = "arn:aws:ecr:us-east-1:000000000000:repository/kaklen-staging-api"
enable_ecs_service     = false

application_bucket_name = "replace-me-kaklen-staging-application"
web_bucket_name         = "replace-me-kaklen-staging-web"

app_public_url       = "https://staging.example.invalid"
app_web_url          = "https://staging.example.invalid"
api_public_url       = "https://api.staging.example.invalid"
marketing_public_url = "https://marketing.staging.example.invalid"
app_version          = "0.1.0"
commit_sha           = "replace-with-git-sha"
build_time           = ""

cloudfront_aliases         = []
cloudfront_certificate_arn = null
alb_certificate_arn        = "arn:aws:acm:us-east-1:000000000000:certificate/00000000-0000-0000-0000-000000000000"

database_deletion_protection          = true
database_performance_insights_enabled = true
database_multi_az                     = false
redis_num_cache_clusters              = 1
enable_sns_alerts                     = false

# Populate SMTP provider CIDRs before enabling transactional email from staging.
lead_notification_email = "leads@example.invalid"
smtp_egress_cidrs        = []
approved_https_egress_cidrs = []
