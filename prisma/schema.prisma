generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                           String                   @id @default(uuid())
  email                        String                   @unique
  firstName                    String
  lastName                     String
  passwordHash                 String
  authVersion                  Int                      @default(0)
  locale                       String                   @default("es")
  status                       UserStatus               @default(ACTIVE)
  emailVerifiedAt              DateTime?
  createdAt                    DateTime                 @default(now())
  updatedAt                    DateTime                 @updatedAt
  refreshTokens                RefreshToken[]
  passwordResetTokens          PasswordResetToken[]
  emailVerificationTokens      EmailVerificationToken[]
  authAuditLogs                AuthAuditLog[]
  createdOrganizations         Organization[]           @relation("OrganizationCreator")
  organizationMemberships      OrganizationMembership[]
  organizationInvitations      OrganizationInvitation[] @relation("InvitationSender")
  organizationAuditLogs        OrganizationAuditLog[]   @relation("OrganizationAuditActor")
  createdClients               Client[]                 @relation("ClientCreator")
  clientInteractions           ClientInteraction[]
  createdCatalogItems          CatalogItem[]            @relation("CatalogItemCreator")
  createdQuotations            Quotation[]              @relation("QuotationCreator")
  quotationStatusChanges       QuotationStatusHistory[] @relation("QuotationStatusChanger")
  createdEvents                Event[]                  @relation("EventCreator")
  assignedEventTasks           EventTask[]              @relation("EventTaskAssignee")
  createdEventTasks            EventTask[]              @relation("EventTaskCreator")
  eventParticipants            EventParticipant[]
  inAppNotifications           InAppNotification[]
  createdQuotationPublicLinks  QuotationPublicLink[]    @relation("QuotationPublicLinkCreator")
  createdWhatsAppNotifications WhatsAppNotification[]   @relation("WhatsAppNotificationCreator")
  providerProfiles             ProviderProfile[]        @relation("ProviderProfileUser")
  calendarIntegrations         CalendarIntegration[]
}

model EmailVerificationToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  revokedAt DateTime?
  sentAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([sentAt])
  @@index([usedAt])
}

model PasswordResetToken {
  id              String    @id @default(uuid())
  userId          String
  tokenHash       String    @unique
  expiresAt       DateTime
  sentAt          DateTime?
  usedAt          DateTime?
  revokedAt       DateTime?
  createdAt       DateTime  @default(now())
  requestedIpHash String?
  userAgentHash   String?
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([sentAt])
  @@index([usedAt])
}

model AuthAuditLog {
  id        String   @id @default(uuid())
  userId    String
  event     String
  success   Boolean
  metadata  Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([event])
  @@index([createdAt])
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  ARCHIVED
}

model Organization {
  id                      String                   @id @default(uuid())
  name                    String
  slug                    String                   @unique
  legalName               String?
  taxId                   String?
  country                 String                   @default("CL")
  currency                String                   @default("CLP")
  timezone                String                   @default("America/Santiago")
  dateFormat              String                   @default("dd-MM-yyyy")
  numberFormat            String                   @default("es")
  defaultLocale           String                   @default("es")
  address                 String?
  phone                   String?
  whatsapp                String?
  status                  OrganizationStatus       @default(ACTIVE)
  createdByUserId         String
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  deletedAt               DateTime?
  createdBy               User                     @relation("OrganizationCreator", fields: [createdByUserId], references: [id])
  memberships             OrganizationMembership[]
  invitations             OrganizationInvitation[]
  auditLogs               OrganizationAuditLog[]
  clients                 Client[]
  clientInteractions      ClientInteraction[]
  catalogItems            CatalogItem[]
  quotations              Quotation[]
  quotationStatusHistory  QuotationStatusHistory[]
  events                  Event[]
  eventTasks              EventTask[]
  eventParticipants       EventParticipant[]
  eventResources          EventResource[]
  eventTimelineEntries    EventTimelineEntry[]
  inAppNotifications      InAppNotification[]
  quotationPublicLinks    QuotationPublicLink[]
  quotationChangeRequests QuotationChangeRequest[]
  whatsappNotifications   WhatsAppNotification[]
  payments                Payment[]
  paymentWebhookEvents    PaymentWebhookEvent[]
  providerProfiles        ProviderProfile[]
  providerAnalyticsEvents ProviderAnalyticsEvent[]
  calendarIntegrations    CalendarIntegration[]

  @@index([createdByUserId])
}

model OrganizationMembership {
  id             String                       @id @default(uuid())
  organizationId String
  userId         String
  role           OrganizationRole
  status         OrganizationMembershipStatus @default(ACTIVE)
  joinedAt       DateTime                     @default(now())
  createdAt      DateTime                     @default(now())
  updatedAt      DateTime                     @updatedAt
  organization   Organization                 @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User                         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
}

model OrganizationInvitation {
  id              String           @id @default(uuid())
  organizationId  String
  email           String
  role            OrganizationRole
  tokenHash       String
  expiresAt       DateTime
  acceptedAt      DateTime?
  revokedAt       DateTime?
  invitedByUserId String
  createdAt       DateTime         @default(now())
  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy       User             @relation("InvitationSender", fields: [invitedByUserId], references: [id])

  @@index([organizationId])
  @@index([email])
}

model OrganizationAuditLog {
  id             String       @id @default(uuid())
  organizationId String
  actorUserId    String
  action         String
  targetType     String
  targetId       String?
  metadata       Json?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actor          User         @relation("OrganizationAuditActor", fields: [actorUserId], references: [id])

  @@index([organizationId])
  @@index([actorUserId])
}

enum OrganizationStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum OrganizationMembershipStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

enum OrganizationRole {
  OWNER
  ADMIN
  MANAGER
  MEMBER
  VIEWER
}

model Client {
  id                String              @id @default(uuid())
  organizationId    String
  type              ClientType
  status            ClientStatus        @default(LEAD)
  displayName       String
  firstName         String?
  lastName          String?
  legalName         String?
  taxId             String?
  email             String?
  phone             String?
  whatsapp          String?
  country           String              @default("CL")
  region            String?
  city              String?
  address           String?
  notes             String?
  createdByUserId   String
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  archivedAt        DateTime?
  organization      Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy         User                @relation("ClientCreator", fields: [createdByUserId], references: [id])
  interactions      ClientInteraction[]
  quotations        Quotation[]
  events            Event[]
  eventParticipants EventParticipant[]
  providerProfiles  ProviderProfile[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, displayName])
  @@index([organizationId, taxId])
}

model ClientInteraction {
  id             String                @id @default(uuid())
  organizationId String
  clientId       String
  userId         String
  type           ClientInteractionType
  subject        String?
  description    String
  occurredAt     DateTime
  createdAt      DateTime              @default(now())
  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client         Client                @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user           User                  @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([organizationId, clientId])
  @@index([organizationId, occurredAt])
}

enum ClientType {
  NATURAL_PERSON
  LEGAL_ENTITY
}

enum ClientStatus {
  LEAD
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum ClientInteractionType {
  NOTE
  CALL
  EMAIL
  MEETING
  WHATSAPP
}

model CatalogItem {
  id              String            @id @default(uuid())
  organizationId  String
  type            CatalogItemType
  status          CatalogItemStatus @default(ACTIVE)
  sku             String?
  code            String
  name            String
  description     String?
  unit            String
  cost            Decimal           @db.Decimal(12, 2)
  price           Decimal           @db.Decimal(12, 2)
  taxPercent      Decimal           @db.Decimal(5, 2)
  currency        String
  trackInventory  Boolean
  createdByUserId String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  archivedAt      DateTime?
  organization    Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy       User              @relation("CatalogItemCreator", fields: [createdByUserId], references: [id])
  quotationItems  QuotationItem[]
  eventResources  EventResource[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, type])
  @@index([organizationId, code])
  @@index([organizationId, sku])
  @@index([organizationId, name])
}

enum CatalogItemType {
  PRODUCT
  SERVICE
}

enum CatalogItemStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

model Quotation {
  id                    String                   @id @default(uuid())
  organizationId        String
  clientId              String
  number                String
  version               Int                      @default(1)
  status                QuotationStatus          @default(DRAFT)
  issueDate             DateTime
  validUntil            DateTime
  currency              String
  globalDiscountPercent Decimal                  @default(0) @db.Decimal(5, 2)
  subtotal              Decimal                  @db.Decimal(14, 2)
  discountTotal         Decimal                  @db.Decimal(14, 2)
  taxTotal              Decimal                  @db.Decimal(14, 2)
  total                 Decimal                  @db.Decimal(14, 2)
  notes                 String?
  terms                 String?
  createdByUserId       String
  approvedAt            DateTime?
  rejectedAt            DateTime?
  sentAt                DateTime?
  paidAt                DateTime?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  archivedAt            DateTime?
  organization          Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client                Client                   @relation(fields: [clientId], references: [id])
  createdBy             User                     @relation("QuotationCreator", fields: [createdByUserId], references: [id])
  items                 QuotationItem[]
  history               QuotationStatusHistory[]
  events                Event[]
  publicLinks           QuotationPublicLink[]
  changeRequests        QuotationChangeRequest[]
  whatsappNotifications WhatsAppNotification[]
  payments              Payment[]

  @@unique([organizationId, number, version])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, clientId])
  @@index([organizationId, issueDate])
  @@index([organizationId, validUntil])
  @@index([organizationId, number])
}

model QuotationItem {
  id            String                @id @default(uuid())
  quotationId   String
  catalogItemId String?
  type          QuotationItemType
  code          String?
  name          String
  description   String?
  quantity      Decimal               @db.Decimal(12, 3)
  unit          String
  unitPrice     Decimal               @db.Decimal(14, 2)
  discountType  QuotationDiscountType @default(NONE)
  discountValue Decimal               @db.Decimal(14, 2)
  taxPercent    Decimal               @db.Decimal(5, 2)
  subtotal      Decimal               @db.Decimal(14, 2)
  discountTotal Decimal               @db.Decimal(14, 2)
  taxTotal      Decimal               @db.Decimal(14, 2)
  total         Decimal               @db.Decimal(14, 2)
  sortOrder     Int
  quotation     Quotation             @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  catalogItem   CatalogItem?          @relation(fields: [catalogItemId], references: [id])

  @@index([quotationId])
  @@index([catalogItemId])
}

model QuotationStatusHistory {
  id              String           @id @default(uuid())
  organizationId  String
  quotationId     String
  previousStatus  QuotationStatus?
  newStatus       QuotationStatus
  changedByUserId String?
  note            String?
  createdAt       DateTime         @default(now())
  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  quotation       Quotation        @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  changedBy       User?            @relation("QuotationStatusChanger", fields: [changedByUserId], references: [id])

  @@index([organizationId])
  @@index([quotationId])
}

enum QuotationStatus {
  DRAFT
  SENT
  CHANGES_REQUESTED
  APPROVED
  REJECTED
  EXPIRED
  CANCELLED
}

enum QuotationItemType {
  PRODUCT
  SERVICE
  CUSTOM
}

enum QuotationDiscountType {
  NONE
  PERCENTAGE
  FIXED
}

model Event {
  id              String               @id @default(uuid())
  organizationId  String
  clientId        String?
  quotationId     String?
  code            String
  name            String
  description     String?
  status          EventStatus          @default(DRAFT)
  startAt         DateTime
  endAt           DateTime
  timezone        String
  venueName       String?
  address         String?
  city            String?
  region          String?
  country         String               @default("CL")
  contactName     String?
  contactEmail    String?
  contactPhone    String?
  budget          Decimal?             @db.Decimal(14, 2)
  currency        String
  notes           String?
  createdByUserId String
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  archivedAt      DateTime?
  organization    Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client          Client?              @relation(fields: [clientId], references: [id])
  quotation       Quotation?           @relation(fields: [quotationId], references: [id])
  createdBy       User                 @relation("EventCreator", fields: [createdByUserId], references: [id])
  tasks           EventTask[]
  participants    EventParticipant[]
  resources       EventResource[]
  timeline        EventTimelineEntry[]
  calendarSyncs   CalendarEventSync[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, clientId])
  @@index([organizationId, quotationId])
  @@index([organizationId, startAt])
  @@index([organizationId, code])
  @@index([organizationId, name])
}

model EventTask {
  id              String            @id @default(uuid())
  organizationId  String
  eventId         String
  title           String
  description     String?
  status          EventTaskStatus   @default(PENDING)
  priority        EventTaskPriority @default(MEDIUM)
  assignedUserId  String?
  dueAt           DateTime?
  completedAt     DateTime?
  createdByUserId String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  organization    Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  event           Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  assignedUser    User?             @relation("EventTaskAssignee", fields: [assignedUserId], references: [id])
  createdBy       User              @relation("EventTaskCreator", fields: [createdByUserId], references: [id])

  @@index([organizationId])
  @@index([eventId])
  @@index([organizationId, status])
  @@index([assignedUserId])
}

model EventParticipant {
  id             String               @id @default(uuid())
  organizationId String
  eventId        String
  userId         String?
  clientId       String?
  externalName   String?
  externalEmail  String?
  externalPhone  String?
  role           EventParticipantRole
  notes          String?
  createdAt      DateTime             @default(now())
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  event          Event                @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user           User?                @relation(fields: [userId], references: [id])
  client         Client?              @relation(fields: [clientId], references: [id])

  @@index([organizationId])
  @@index([eventId])
  @@index([userId])
  @@index([clientId])
}

model EventResource {
  id             String       @id @default(uuid())
  organizationId String
  eventId        String
  catalogItemId  String?
  name           String
  quantity       Decimal      @db.Decimal(12, 3)
  unit           String
  unitCost       Decimal?     @db.Decimal(14, 2)
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  event          Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  catalogItem    CatalogItem? @relation(fields: [catalogItemId], references: [id])

  @@index([organizationId])
  @@index([eventId])
  @@index([catalogItemId])
}

model EventTimelineEntry {
  id             String       @id @default(uuid())
  organizationId String
  eventId        String
  title          String
  description    String?
  startsAt       DateTime
  endsAt         DateTime?
  sortOrder      Int
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  event          Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([eventId])
  @@index([organizationId, startsAt])
}

enum EventStatus {
  DRAFT
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  ARCHIVED
}

enum EventTaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum EventTaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum EventParticipantRole {
  OWNER
  COORDINATOR
  STAFF
  SUPPLIER
  CLIENT_CONTACT
  GUEST
}

model InAppNotification {
  id             String                @id @default(uuid())
  organizationId String
  userId         String
  type           InAppNotificationType
  title          String
  body           String
  resourceType   String
  resourceId     String?
  route          String?
  readAt         DateTime?
  createdAt      DateTime              @default(now())
  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId, userId, readAt])
  @@index([organizationId, createdAt])
  @@index([resourceType, resourceId])
}

enum InAppNotificationType {
  QUOTATION_VIEWED
  QUOTATION_CHANGES_REQUESTED
  QUOTATION_APPROVED
  PAYMENT_STARTED
  PAYMENT_CONFIRMED
  PAYMENT_FAILED
  PUBLIC_LINK_EXPIRED
  QUOTATION_VERSION_CREATED
  EVENT_UPCOMING
}

model QuotationPublicLink {
  id                    String                   @id @default(uuid())
  organizationId        String
  quotationId           String
  tokenHash             String                   @unique
  expiresAt             DateTime
  revokedAt             DateTime?
  lastViewedAt          DateTime?
  createdByUserId       String
  createdAt             DateTime                 @default(now())
  organization          Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  quotation             Quotation                @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  createdBy             User                     @relation("QuotationPublicLinkCreator", fields: [createdByUserId], references: [id])
  changeRequests        QuotationChangeRequest[]
  whatsappNotifications WhatsAppNotification[]
  payments              Payment[]

  @@index([organizationId, quotationId])
  @@index([expiresAt])
  @@index([revokedAt])
}

model QuotationChangeRequest {
  id             String              @id @default(uuid())
  organizationId String
  quotationId    String
  publicLinkId   String
  comment        String
  itemIndexes    Json?
  createdAt      DateTime            @default(now())
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  quotation      Quotation           @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  publicLink     QuotationPublicLink @relation(fields: [publicLinkId], references: [id], onDelete: Cascade)

  @@index([organizationId, quotationId])
  @@index([publicLinkId])
}

model WhatsAppNotification {
  id                String                     @id @default(uuid())
  organizationId    String
  quotationId       String
  publicLinkId      String
  createdByUserId   String
  recipientHash     String
  status            WhatsAppNotificationStatus @default(PENDING)
  providerMessageId String?
  preparedAt        DateTime?
  sentAt            DateTime?
  failedAt          DateTime?
  openedAt          DateTime?
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt
  organization      Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  quotation         Quotation                  @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  publicLink        QuotationPublicLink        @relation(fields: [publicLinkId], references: [id], onDelete: Cascade)
  createdBy         User                       @relation("WhatsAppNotificationCreator", fields: [createdByUserId], references: [id])

  @@index([organizationId, quotationId])
  @@index([status])
}

enum WhatsAppNotificationStatus {
  PENDING
  PREPARED
  SENT
  FAILED
  OPENED
}

model Payment {
  id                String                @id @default(uuid())
  organizationId    String
  quotationId       String
  publicLinkId      String?
  provider          PaymentProvider       @default(SANDBOX)
  status            PaymentStatus         @default(PENDING)
  amount            Decimal               @db.Decimal(14, 2)
  currency          String
  idempotencyKey    String
  externalReference String                @unique
  checkoutTokenHash String?               @unique
  paidAt            DateTime?
  cancelledAt       DateTime?
  failedAt          DateTime?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  organization      Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  quotation         Quotation             @relation(fields: [quotationId], references: [id])
  publicLink        QuotationPublicLink?  @relation(fields: [publicLinkId], references: [id])
  attempts          PaymentAttempt[]
  webhookEvents     PaymentWebhookEvent[]
  refunds           PaymentRefund[]
  receipt           PaymentReceipt?

  @@unique([organizationId, idempotencyKey])
  @@index([organizationId, quotationId])
  @@index([organizationId, status])
}

model PaymentAttempt {
  id                String        @id @default(uuid())
  paymentId         String
  status            PaymentStatus
  providerReference String?
  errorCode         String?
  createdAt         DateTime      @default(now())
  payment           Payment       @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId, createdAt])
}

model PaymentWebhookEvent {
  id              String          @id @default(uuid())
  organizationId  String
  paymentId       String?
  provider        PaymentProvider
  providerEventId String          @unique
  payloadHash     String
  signatureValid  Boolean
  processedAt     DateTime?
  createdAt       DateTime        @default(now())
  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  payment         Payment?        @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([paymentId])
}

model PaymentRefund {
  id                String        @id @default(uuid())
  paymentId         String
  amount            Decimal       @db.Decimal(14, 2)
  status            PaymentStatus @default(PROCESSING)
  providerReference String?
  reason            String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  payment           Payment       @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId])
}

model PaymentReceipt {
  id            String   @id @default(uuid())
  paymentId     String   @unique
  receiptNumber String   @unique
  issuedAt      DateTime @default(now())
  metadata      Json?
  payment       Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
}

enum PaymentProvider {
  SANDBOX
}

enum PaymentStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
  CANCELLED
  REFUNDED
  PARTIALLY_REFUNDED
}

model ProviderProfile {
  id              String                   @id @default(uuid())
  organizationId  String
  sourceClientId  String
  userId          String?
  category        String
  description     String
  country         String
  region          String?
  city            String?
  whatsapp        String
  price           Decimal?                 @db.Decimal(14, 2)
  currency        String
  portfolioUrl    String?
  status          ProviderProfileStatus    @default(DRAFT)
  consentAt       DateTime
  reviewedAt      DateTime?
  publishedAt     DateTime?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  organization    Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sourceClient    Client                   @relation(fields: [sourceClientId], references: [id])
  user            User?                    @relation("ProviderProfileUser", fields: [userId], references: [id])
  analyticsEvents ProviderAnalyticsEvent[]

  @@unique([organizationId, sourceClientId])
  @@index([organizationId, status])
  @@index([sourceClientId])
  @@index([userId])
}

model ProviderAnalyticsEvent {
  id             String                     @id @default(uuid())
  organizationId String
  profileId      String?
  event          ProviderAnalyticsEventType
  createdAt      DateTime                   @default(now())
  organization   Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  profile        ProviderProfile?           @relation(fields: [profileId], references: [id], onDelete: SetNull)

  @@index([organizationId, event, createdAt])
  @@index([profileId])
}

enum ProviderProfileStatus {
  DRAFT
  IN_REVIEW
  PUBLISHED
  ARCHIVED
}

enum ProviderAnalyticsEventType {
  RECOMMENDATION_SHOWN
  PROVIDER_SIGNUP_STARTED
  PROVIDER_PROFILE_COMPLETED
}

model Lead {
  id                 String              @id @default(uuid())
  firstName          String
  lastName           String
  email              String
  phoneCountryCode   String
  phoneE164          String
  company            String?
  position           String?
  country            String?
  interestType       LeadInterest
  message            String
  privacyConsent     Boolean
  whatsappConsent    Boolean
  consentTextVersion String
  consentRecordedAt  DateTime
  consentIpHash      String?
  userAgentHash      String?
  source             String              @default("kaklen-marketing")
  utmSource          String?
  utmMedium          String?
  utmCampaign        String?
  utmContent         String?
  landingPage        String?
  referrer           String?
  status             LeadStatus          @default(NEW)
  whatsappStatus     LeadWhatsAppStatus?
  whatsappSentAt     DateTime?
  whatsappError      String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  events             LeadEvent[]

  @@index([email])
  @@index([phoneE164])
  @@index([status])
  @@index([createdAt])
}

model LeadEvent {
  id        String   @id @default(uuid())
  leadId    String
  eventType String
  metadata  Json?
  createdAt DateTime @default(now())
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Restrict)

  @@index([leadId])
}

enum LeadInterest {
  ADVISORY
  KAKLEN
  PLATFORM_DEVELOPMENT
  DIGITAL_TRANSFORMATION
  INVESTMENT_PARTNERSHIP
  KAPIAR
  OTHER
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  OPPORTUNITY
  CLOSED_WON
  CLOSED_LOST
  ARCHIVED
}

enum LeadWhatsAppStatus {
  PENDING
  SENT
  FAILED
}

// ─── Calendar Integration ───────────────────────────────────────────────────

enum CalendarProvider {
  GOOGLE
  MICROSOFT
  APPLE
}

enum CalendarSyncStatus {
  SYNCED
  PENDING
  FAILED
  CONFLICT
}

model CalendarIntegration {
  id                String            @id @default(uuid())
  userId            String
  organizationId    String
  provider          CalendarProvider
  externalAccountId String?
  accessToken       String
  refreshToken      String
  tokenExpiresAt    DateTime
  calendarId        String            @default("primary")
  webhookChannelId  String?
  webhookResourceId String?
  webhookExpiresAt  DateTime?
  enabled           Boolean           @default(true)
  lastSyncAt        DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization      Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  syncedEvents      CalendarEventSync[]

  @@unique([userId, organizationId, provider])
  @@index([userId])
  @@index([organizationId])
  @@index([webhookChannelId])
}

model CalendarEventSync {
  id                    String              @id @default(uuid())
  calendarIntegrationId String
  eventId               String
  externalEventId       String
  syncStatus            CalendarSyncStatus  @default(PENDING)
  lastSyncedAt          DateTime?
  syncError             String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  calendarIntegration   CalendarIntegration @relation(fields: [calendarIntegrationId], references: [id], onDelete: Cascade)
  event                 Event               @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([calendarIntegrationId, eventId])
  @@unique([calendarIntegrationId, externalEventId])
  @@index([eventId])
  @@index([syncStatus])
}
