# Generated from docs/configuration/environment-variables.json.
# Local development only. Known local secrets below must never be reused in production.

# Local bootstrap
# Primary web origin used by organization invitations.
APP_WEB_URL=http://localhost:4200
# Comma-separated origin allow-list for refresh and logout requests.
AUTH_ALLOWED_ORIGINS=http://localhost:4200
# Requires HTTPS-only authentication cookies.
COOKIE_SECURE=false
# Comma-separated CORS origin allow-list.
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:4300
# Prisma PostgreSQL connection URL. Local development secret only.
DATABASE_URL=postgresql://kaklen:kaklen_dev_password@localhost:5432/kaklen_dev?schema=public
# Cryptographic secret used to sign access tokens. Local development secret only.
JWT_ACCESS_SECRET=local-only-jwt-access-secret-not-for-production
# Independent cryptographic secret used for refresh tokens. Local development secret only.
JWT_REFRESH_SECRET=local-only-jwt-refresh-secret-not-for-production
# Internal recipient notified whenever the marketing site captures a new lead.
LEAD_NOTIFICATION_EMAIL=leads@kaklen.local
# Published SMTP port for local Mailpit.
MAILPIT_SMTP_PORT=1025
# Published HTTP port for local Mailpit.
MAILPIT_WEB_PORT=8025
# Port used by the marketing site's dev and start scripts.
MARKETING_PORT=4300
# Public origin of the marketing site; used for outbound links in lead notifications.
MARKETING_SITE_URL=http://localhost:4300
# Public API base URL embedded in the marketing build.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api
# Public Instagram profile linked by the marketing site.
NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/kaklen.cl
# Canonical public origin embedded in marketing metadata and JSON-LD.
NEXT_PUBLIC_SITE_URL=http://localhost:4300
# Organization invitation lifetime in seconds.
ORGANIZATION_INVITATION_EXPIRES_SECONDS=259200
# Published local PostgreSQL port.
POSTGRES_PORT=5432
# Published Redis port for local and CI services.
REDIS_PORT=6379
