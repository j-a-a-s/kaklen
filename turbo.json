{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": [
    "API_PORT",
    "API_TEST_WITH_COVERAGE",
    "APP_VERSION",
    "BUILD_TIME",
    "COMMIT_SHA",
    "DATABASE_URL",
    "MARKETING_PORT",
    "POSTGRES_PORT",
    "PUBLIC_APP_ENVIRONMENT",
    "WEB_PORT"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "out-tsc/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "@kaklen/api#test": {
      "dependsOn": ["^build"],
      "env": ["API_TEST_WITH_COVERAGE"],
      "outputs": ["coverage/**"]
    },
    "test:unit": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test:integration": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "lint": {
      "dependsOn": ["^build"],
      "outputs": []
    }
  }
}
