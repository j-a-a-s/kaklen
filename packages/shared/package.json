{
  "name": "@kaklen/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./chilean-rut": {
      "types": "./runtime/chilean-rut.d.ts",
      "require": "./runtime/chilean-rut.cjs",
      "default": "./runtime/chilean-rut.cjs"
    }
  },
  "typesVersions": {
    "*": {
      "chilean-rut": ["runtime/chilean-rut.d.ts"]
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "test": "pnpm run build && node --test tests/*.test.mjs",
    "test:unit": "pnpm run build && node --test tests/*.test.mjs",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
