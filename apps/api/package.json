{
  "name": "@kaklen/api",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "type": "commonjs",
  "scripts": {
    "clean": "node ../../scripts/clean-api-dist.mjs",
    "build": "pnpm run clean && tsc -p tsconfig.build.json && node ../../scripts/verify-api-build.mjs --files-only",
    "dev": "pnpm run clean && DATABASE_URL=${DATABASE_URL:-postgresql://kaklen:kaklen_dev_password@localhost:${POSTGRES_PORT:-5432}/kaklen_dev?schema=public} nest start --watch",
    "start": "node ../../scripts/verify-api-build.mjs --files-only && DATABASE_URL=${DATABASE_URL:-postgresql://kaklen:kaklen_dev_password@localhost:${POSTGRES_PORT:-5432}/kaklen_dev?schema=public} node dist/main.js",
    "test": "node ../../scripts/run-api-tests.mjs",
    "test:unit": "node ../../scripts/run-api-tests.mjs --unit",
    "test:integration": "node ../../scripts/run-api-tests.mjs --integration",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.940.0",
    "@kokecore/auth": "link:../../../kokecore/packages/auth",
    "@kokecore/calendar": "link:../../../kokecore/packages/calendar",
    "@kokecore/errors": "link:../../../kokecore/packages/errors",
    "@kokecore/logging": "link:../../../kokecore/packages/logging",
    "@kokecore/rbac": "link:../../../kokecore/packages/rbac",
    "@kokecore/storage": "link:../../../kokecore/packages/storage",
    "@kokecore/validation": "link:../../../kokecore/packages/validation",
    "@aws-sdk/s3-request-presigner": "^3.940.0",
    "@kaklen/config": "workspace:*",
    "@kaklen/shared": "workspace:*",
    "@nestjs/common": "^11.1.3",
    "@nestjs/core": "^11.1.3",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.1.3",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/throttler": "^6.4.0",
    "@prisma/client": "^6.11.1",
    "argon2": "^0.44.0",
    "bullmq": "^5.80.9",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "cookie-parser": "^1.4.7",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.11.1",
    "nodemailer": "^9.0.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.7",
    "@nestjs/schematics": "^11.0.5",
    "@nestjs/testing": "^11.1.3",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.15.32",
    "@types/nodemailer": "^8.0.1",
    "@types/supertest": "^6.0.3",
    "jest": "^30.0.3",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.0",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
