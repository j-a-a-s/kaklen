{
  "name": "@kaklen/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "ngc -p tsconfig.app.json",
    "build:es": "ngc -p tsconfig.es.json",
    "build:en": "ngc -p tsconfig.en.json",
    "build:pt-BR": "ngc -p tsconfig.pt-BR.json",
    "dev": "ng serve --host 0.0.0.0 --port 4200",
    "extract-i18n": "ng extract-i18n --format xlf --output-path src/locale",
    "test": "tsc -p tsconfig.app.json --noEmit",
    "lint": "tsc -p tsconfig.app.json --noEmit"
  },
  "dependencies": {
    "@angular/animations": "^20.0.5",
    "@angular/common": "^20.0.5",
    "@angular/compiler": "^20.0.5",
    "@angular/core": "^20.0.5",
    "@angular/forms": "^20.0.5",
    "@angular/localize": "^20.0.5",
    "@angular/platform-browser": "^20.0.5",
    "@angular/router": "^20.0.5",
    "@kaklen/shared": "workspace:*",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "^0.15.1"
  },
  "devDependencies": {
    "@angular/build": "^20.0.5",
    "@angular/cli": "^20.0.5",
    "@angular/compiler-cli": "^20.0.5",
    "@types/node": "^22.15.32",
    "karma": "^6.4.4",
    "karma-chrome-launcher": "^3.2.0",
    "karma-coverage": "^2.2.1",
    "karma-jasmine": "^5.1.0",
    "jasmine-core": "^5.7.1",
    "typescript": "^5.8.3"
  }
}
