# Generated from docs/configuration/environment-variables.json.
# Production contract: fill every required value in the deployment secret/config store.

# Required in production
# Public web origin used to build verification, recovery and portal links.
APP_PUBLIC_URL=https://app.example.com
# Application version exposed by runtime config and health endpoints.
APP_VERSION=
# Primary web origin used by organization invitations.
APP_WEB_URL=https://app.example.com
# Comma-separated origin allow-list for refresh and logout requests.
AUTH_ALLOWED_ORIGINS=https://app.example.com
# AWS region used by the S3 client.
AWS_REGION=us-east-1
# S3 bucket that stores application objects.
AWS_S3_BUCKET=kaklen-production
# Source revision exposed by runtime metadata.
COMMIT_SHA=
# Requires HTTPS-only authentication cookies.
COOKIE_SECURE=true
# Comma-separated CORS origin allow-list.
CORS_ALLOWED_ORIGINS=https://app.example.com,https://kaklen.cl
# Enforces TLS for PostgreSQL and requires sslmode=require in production.
DATABASE_SSL=true
# Prisma PostgreSQL connection URL. Secret: inject securely; intentionally empty.
DATABASE_URL=
# Cryptographic secret used to sign access tokens. Secret: inject securely; intentionally empty.
JWT_ACCESS_SECRET=
# Independent cryptographic secret used for refresh tokens. Secret: inject securely; intentionally empty.
JWT_REFRESH_SECRET=
# Internal recipient notified whenever the marketing site captures a new lead.
LEAD_NOTIFICATION_EMAIL=leads@example.com
# Sender identity for application email.
MAIL_FROM="Kaklen <no-reply@example.com>"
# SMTP server hostname.
MAIL_HOST=smtp.example.com
# Public origin of the marketing site; used for outbound links in lead notifications.
MARKETING_SITE_URL=https://kaklen.cl
# Public API base URL embedded in the marketing build.
NEXT_PUBLIC_API_BASE_URL=https://api.example.com/api
# Canonical public origin embedded in marketing metadata and JSON-LD.
NEXT_PUBLIC_SITE_URL=https://kaklen.example.com
# Node runtime environment selector.
NODE_ENV=production
# Cryptographic secret for sandbox payment callbacks. Secret: inject securely; intentionally empty.
PAYMENT_SANDBOX_SECRET=
# HMAC secret for distributed rate-limit identifiers. Secret: inject securely; intentionally empty.
RATE_LIMIT_HASH_SECRET=
# Redis connection URL for distributed limits and BullMQ; production requires rediss:// on a non-loopback managed endpoint. Secret: inject securely; intentionally empty.
REDIS_URL=
# HMAC secret for WhatsApp operational identifiers. Secret: inject securely; intentionally empty.
WHATSAPP_HASH_SECRET=

# Optional in production
# Fallback API port used by runtime and local orchestration.
API_PORT=3000
# Enables transactional authentication email delivery.
AUTH_EMAIL_ENABLED=true
# Optional CloudFront domain used for public object delivery.
AWS_CLOUDFRONT_DOMAIN=cdn.example.com
# Optional S3-compatible endpoint override.
AWS_S3_ENDPOINT=
# ISO timestamp embedded in runtime metadata.
BUILD_TIME=
# Enables commercial email capabilities independently from auth email.
COMMERCIAL_EMAIL_ENABLED=false
# Email-verification token lifetime in minutes.
EMAIL_VERIFICATION_EXPIRES_MINUTES=1440
# Access-token lifetime in seconds.
JWT_ACCESS_EXPIRES_SECONDS=900
# Refresh-token lifetime in seconds.
JWT_REFRESH_EXPIRES_SECONDS=604800
# Structured API logging threshold.
LOG_LEVEL=info
# SMTP connection timeout in milliseconds.
MAIL_CONNECTION_TIMEOUT_MS=5000
# SMTP greeting timeout in milliseconds.
MAIL_GREETING_TIMEOUT_MS=5000
# Optional SMTP password paired with MAIL_USER. Secret: inject securely; intentionally empty.
MAIL_PASSWORD=
# SMTP server port.
MAIL_PORT=587
# Enables implicit TLS for SMTP.
MAIL_SECURE=false
# SMTP socket timeout in milliseconds.
MAIL_SOCKET_TIMEOUT_MS=10000
# Optional SMTP username paired with MAIL_PASSWORD.
MAIL_USER=
# Port used by the marketing site's dev and start scripts.
MARKETING_PORT=4300
# Public Instagram profile linked by the marketing site.
NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/kaklen.cl
# Organization invitation lifetime in seconds.
ORGANIZATION_INVITATION_EXPIRES_SECONDS=259200
# Password-reset token lifetime in minutes.
PASSWORD_RESET_EXPIRES_MINUTES=30
# Configured payment gateway mode.
PAYMENT_GATEWAY=sandbox
# Primary API listening port.
PORT=3000
# API base URL written into public web runtime config.
PUBLIC_API_BASE_URL=https://api.example.com/api
# Public environment label exposed by web and health metadata.
PUBLIC_APP_ENVIRONMENT=production
# Frontend idle-session timeout in seconds.
SESSION_IDLE_SECONDS=300
# Frontend idle warning threshold in seconds.
SESSION_WARNING_SECONDS=240
# Enables Swagger outside production; production always disables it.
SWAGGER_ENABLED=false
# Enables trusted proxy handling for the deployed topology.
TRUST_PROXY=true
# Selects manual or provider-backed WhatsApp delivery.
WHATSAPP_MODE=manual
