{
  "name": "kaklen",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo run build --filter='./packages/*' && turbo run dev --filter='./apps/*' --parallel",
    "build": "turbo run build --concurrency=1",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "web:runtime-config": "node scripts/write-runtime-config.mjs",
    "db:generate": "pnpm prisma:generate",
    "db:migrate:deploy": "DATABASE_URL=${DATABASE_URL:?DATABASE_URL is required} prisma migrate deploy",
    "db:status": "DATABASE_URL=${DATABASE_URL:-postgresql://kaklen:kaklen@localhost:${POSTGRES_PORT:-5432}/kaklen?schema=public} prisma migrate status",
    "prisma:generate": "DATABASE_URL=${DATABASE_URL:-postgresql://kaklen:kaklen@localhost:${POSTGRES_PORT:-5432}/kaklen?schema=public} prisma generate",
    "prisma:migrate": "DATABASE_URL=${DATABASE_URL:-postgresql://kaklen:kaklen@localhost:${POSTGRES_PORT:-5432}/kaklen?schema=public} prisma migrate dev --name init",
    "prisma:studio": "DATABASE_URL=${DATABASE_URL:-postgresql://kaklen:kaklen@localhost:${POSTGRES_PORT:-5432}/kaklen?schema=public} prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^6.11.1"
  },
  "devDependencies": {
    "prisma": "^6.11.1",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  }
}
