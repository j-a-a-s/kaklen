{
  "name": "kaklen",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=22 <25",
    "pnpm": ">=9.15.4 <10"
  },
  "scripts": {
    "dev": "turbo run build --filter='./packages/*' && turbo run dev --filter='./apps/*' --parallel",
    "dev:i18n": "node scripts/dev-i18n.mjs",
    "dev:full:i18n": "node scripts/dev-full-i18n.mjs",
    "dev:fresh": "node scripts/dev-fresh.mjs",
    "build": "turbo run build --concurrency=1",
    "build:fresh": "node scripts/build-fresh.mjs",
    "test": "node --test scripts/*.test.mjs && turbo run test",
    "test:coverage": "node scripts/test-coverage.mjs",
    "test:mutation:critical": "node scripts/test-mutation-critical.mjs",
    "accessibility:test": "playwright test e2e/accessibility.spec.mjs",
    "lint": "turbo run lint",
    "architecture:check": "node scripts/check-architecture.mjs",
    "quality:scan": "node scripts/quality-scan.mjs",
    "quality:gate": "node scripts/quality-gate.mjs",
    "security:sast": "node scripts/static-security-scan.mjs",
    "security:sbom": "node scripts/generate-sbom.mjs",
    "clean": "pnpm clean:dev",
    "clean:dev": "node scripts/clean-dev.mjs",
    "web:runtime-config": "node scripts/write-runtime-config.mjs",
    "i18n:sync": "node scripts/sync-assisted-i18n.mjs",
    "db:generate": "pnpm prisma:generate",
    "db:migrate:deploy": "DATABASE_URL=${DATABASE_URL:?DATABASE_URL is required} prisma migrate deploy",
    "db:status": "DATABASE_URL=${DATABASE_URL:-postgresql://kaklen:kaklen_dev_password@localhost:${POSTGRES_PORT:-5432}/kaklen_dev?schema=public} prisma migrate status",
    "db:seed": "node scripts/seed-dev.mjs",
    "db:seed:demo": "node scripts/seed-demo.mjs",
    "db:clear:demo": "node scripts/clear-demo.mjs",
    "db:verify:demo": "node scripts/verify-demo.mjs",
    "db:reset:dev": "node scripts/db-reset-dev.mjs",
    "db:validate": "node scripts/db-validate.mjs",
    "doctor": "node scripts/doctor.mjs",
    "setup": "node scripts/init-local.mjs",
    "verify": "pnpm run doctor && pnpm lint && pnpm test && pnpm build",
    "verify:api-build": "node scripts/verify-api-build.mjs",
    "verify:api-start": "node scripts/verify-api-start.mjs",
    "verify:i18n-server": "node scripts/verify-i18n-server.mjs",
    "verify:full-local": "node scripts/verify-full-local.mjs",
    "security:scan": "node scripts/scan-secrets.mjs",
    "release:check": "node scripts/release-check.mjs",
    "release:check:strict": "node scripts/release-check-strict.mjs",
    "dependency:audit": "node scripts/dependency-audit.mjs",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "screenshots:assisted": "node scripts/capture-assisted-screenshots.mjs",
    "prisma:generate": "DATABASE_URL=${DATABASE_URL:-postgresql://kaklen:kaklen_dev_password@localhost:${POSTGRES_PORT:-5432}/kaklen_dev?schema=public} prisma generate",
    "prisma:migrate": "DATABASE_URL=${DATABASE_URL:-postgresql://kaklen:kaklen_dev_password@localhost:${POSTGRES_PORT:-5432}/kaklen_dev?schema=public} prisma migrate dev --name init",
    "prisma:studio": "DATABASE_URL=${DATABASE_URL:-postgresql://kaklen:kaklen_dev_password@localhost:${POSTGRES_PORT:-5432}/kaklen_dev?schema=public} prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^6.11.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "pg": "^8.16.3",
    "prisma": "^6.11.1",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  }
}
