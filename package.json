{
  "name": "kaklen",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo run build --filter='./packages/*' && turbo run dev --filter='./apps/*' --parallel",
    "dev:i18n": "node scripts/dev-i18n.mjs",
    "dev:fresh": "node scripts/dev-fresh.mjs",
    "build": "turbo run build --concurrency=1",
    "build:fresh": "node scripts/build-fresh.mjs",
    "test": "node --test scripts/*.test.mjs && turbo run test",
    "lint": "turbo run lint",
    "clean": "pnpm clean:dev",
    "clean:dev": "node scripts/clean-dev.mjs",
    "web:runtime-config": "node scripts/write-runtime-config.mjs",
    "db:generate": "pnpm prisma:generate",
    "db:migrate:deploy": "DATABASE_URL=${DATABASE_URL:?DATABASE_URL is required} prisma migrate deploy",
    "db:status": "DATABASE_URL=${DATABASE_URL:-postgresql://kaklen:kaklen_dev_password@localhost:${POSTGRES_PORT:-5432}/kaklen_dev?schema=public} prisma migrate status",
    "doctor": "node scripts/doctor.mjs",
    "setup": "node scripts/init-local.mjs",
    "verify": "pnpm run doctor && pnpm lint && pnpm test && pnpm build",
    "verify:i18n-server": "node scripts/verify-i18n-server.mjs",
    "prisma:generate": "DATABASE_URL=${DATABASE_URL:-postgresql://kaklen:kaklen_dev_password@localhost:${POSTGRES_PORT:-5432}/kaklen_dev?schema=public} prisma generate",
    "prisma:migrate": "DATABASE_URL=${DATABASE_URL:-postgresql://kaklen:kaklen_dev_password@localhost:${POSTGRES_PORT:-5432}/kaklen_dev?schema=public} prisma migrate dev --name init",
    "prisma:studio": "DATABASE_URL=${DATABASE_URL:-postgresql://kaklen:kaklen_dev_password@localhost:${POSTGRES_PORT:-5432}/kaklen_dev?schema=public} prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^6.11.1"
  },
  "devDependencies": {
    "pg": "^8.16.3",
    "prisma": "^6.11.1",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  }
}
